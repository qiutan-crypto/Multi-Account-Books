# Template — copy to .env.local and fill in your real values.
# Next.js loads .env.local automatically; this example file is never loaded.
#
# Storage backend selection (see lib/store/index.ts):
#   1. Supabase  — set SUPABASE_URL + a server key; run supabase/schema.sql once.
#   2. Vercel Blob — connect a Blob store in Vercel (BLOB_READ_WRITE_TOKEN).
#   3. Filesystem — default for local dev (files under data/).

# Supabase (recommended): Dashboard -> Project Settings -> API
# SUPABASE_URL is the full "Project URL", i.e. https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY accepts either the legacy service_role JWT or a
# new-style Secret key (starts with sb_secret_...). Server-side only — never
# expose it to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Optional: admin password for deleting companies from the UI
ADMIN_PASSWORD=
